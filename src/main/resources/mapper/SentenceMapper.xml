<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.anno.mapper.SentenceMapper">

    <!-- 문장 조회 -->
    <select id="selectSentence" parameterType="Sentence" resultType="Sentence">
        SELECT
            ID,
            TEXT,
            TREE_GROUP_ID,
            IDX
        FROM SENTENCE
        WHERE ID = #{id}
    </select>

    <!-- 문장 등록 -->
    <insert id="insertSentence" parameterType="Sentence" keyProperty="id">
        <selectKey keyProperty="id" resultType="string" order="BEFORE">
            SELECT SENTENCE_SEQ.NEXTVAL FROM DUAL
        </selectKey>

        INSERT INTO SENTENCE (
            ID,
            TEXT,
            TREE_GROUP_ID,
            IDX
        ) VALUES (
            #{id},
            #{text},
            #{treeGroupId},
            #{idx}
        )
    </insert>

    <!--  문장 수정 -->
    <update id="updateSentence" parameterType="Sentence">
        UPDATE SENTENCE
        SET
            TEXT = #{text},
            IDX = #{idx},
            UPDATE_DT = SYSDATE
        WHERE ID = #{id}
    </update>

