    <!-- 문장 삭제 -->
    <delete id="deleteSentence" parameterType="Sentence">
        DELETE FROM SENTENCE
        WHERE ID = #{id}
    </delete>

    <!-- 문장 삭제(Tree 전체) -->
    <delete id="deleteSentenceTree" parameterType="string">
        DELETE FROM SENTENCE
        WHERE TREE_GROUP_ID = #{id}
    </delete>
</mapper>
